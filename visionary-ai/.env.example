# ── Visionary AI — Environment Config ──────────────────────────
# Copy this file to .env and fill in your values.

# Paste the ngrok URL printed by your Colab notebook
COLAB_API_URL=https://your-ngrok-url.ngrok-free.app

# Max conversation messages kept in memory (default 10)
MAX_HISTORY=10

# Max requests per IP per minute (default 20)
RATE_LIMIT_PER_MINUTE=20
